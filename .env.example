# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=sqlite:///flower_shop.db
# Uncomment for MySQL
# DATABASE_URL=mysql+pymysql://username:password@localhost/flower_shop

# Upload Settings
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# Server
DEBUG=True
TESTING=False
